@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<nav class="navbar">
    <div class="nav-left">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>

        <div class="dropdown">
            <a href="#" class="dropdown-toggle">Danh mục </a>
            <ul class="dropdown-menu">
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="TruyenThong">Trọ truyền thống</a></li>
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="Ghep">Trọ ghép</a></li>
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="ChungCuMini">Chung cư mini</a></li>
            </ul>
        </div>

        <a asp-controller="Home" asp-action="Index">Chính sách bảo mật</a>
        <a asp-controller="Tro" asp-action="Index">Hỗ trợ</a>
    </div>

    <div class="nav-right">
        <a asp-controller="Search" asp-action="Search" class="btn btn-primary">
            🔍 Tìm Kiếm
        </a>

        @if (User.Identity.IsAuthenticated)
        {
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Tro" asp-action="Create" class="btn btn-register">
                    + Đăng tin
                </a>
                <a asp-controller="Khachthue" asp-action="Bookings" class="nav-link d-inline-block">
                    Booking của tôi
                </a>
            }
            else
            {
                <a asp-controller="Booking" asp-action="Index" class="nav-link d-inline-block">
                    Đặt phòng
                </a>
            }

            <div class="dropdown d-inline-block">
                <a class="btn btn-login dropdown-toggle" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    👤
                </a>

                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                    <li><h6 class="dropdown-header">Xin chào, @User.Identity.Name</h6></li>
                    <li><hr class="dropdown-divider"></li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard">Quản trị hệ thống</a></li>
                        <li><a class="dropdown-item" asp-controller="Tro" asp-action="Manage">Quản lý bài đăng</a></li>
                    }
                    else
                    {
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Thông tin cá nhân</a></li>
                        <li><a class="dropdown-item" asp-controller="Booking" asp-action="History">Lịch sử đặt phòng</a></li>
                        <li><a class="dropdown-item" asp-controller="Khachthue" asp-action="Favorites">Phòng yêu thích</a></li>
                    }

                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-login">
                Đăng nhập
            </a>

            <a asp-controller="Account" asp-action="Register" class="btn btn-register">
                Đăng ký
            </a>
        }
    </div>
</nav>