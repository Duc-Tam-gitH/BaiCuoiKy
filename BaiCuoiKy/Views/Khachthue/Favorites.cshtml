@model IEnumerable<BaiCuoiKy.Models.Tro>

@{
    ViewData["Title"] = "Phòng trọ đã lưu";
}

<div class="favorites-wrapper">
    <div class="container py-5">

        <!-- Header -->
        <div class="fav-header d-flex align-items-center justify-content-between mb-5">
            <div class="d-flex align-items-center gap-3">
                <div class="header-icon-wrap">
                    <i class="fa-solid fa-heart"></i>
                </div>
                <div>
                    <p class="fav-label mb-0">Danh sách của bạn</p>
                    <h2 class="fav-title mb-0">Phòng trọ yêu thích</h2>
                </div>
            </div>
            <span class="fav-count-badge">
                <i class="fa-solid fa-bookmark me-1"></i> @Model.Count() Phòng lưu
            </span>
        </div>

        <!-- Cards -->
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">
                        <div class="fav-card">
                            <!-- Image -->
                            <div class="fav-card-img">
                                <img src="@(item.AnhPhongs?.FirstOrDefault()?.Url ?? "/images/no-image.jpg")"
                                     alt="@item.TieuDe">
                                <div class="fav-price-tag">
                                    <i class="fa-solid fa-tag me-1"></i>@item.Gia.ToString("N0") VNĐ/tháng
                                </div>
                                <div class="fav-card-overlay"></div>
                            </div>

                            <!-- Body -->
                            <div class="fav-card-body">
                                <h5 class="fav-card-title">@item.TieuDe</h5>
                                <p class="fav-card-address">
                                    <i class="fa-solid fa-location-dot me-1"></i> @item.DiaChi
                                </p>

                                <div class="fav-card-actions">
                                    <a asp-controller="Tro" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn-detail">
                                        <span>Xem chi tiết</span>
                                        <i class="fa-solid fa-arrow-right ms-2"></i>
                                    </a>

                                    <form asp-controller="Favorite" asp-action="ToggleFavorite" asp-route-troId="@item.Id" method="post">
                                        <button type="submit" class="btn-remove">
                                            <i class="fa-solid fa-trash-can me-1"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <div class="empty-icon-wrap">
                            <i class="fa-solid fa-heart-crack"></i>
                        </div>
                        <h3 class="empty-title">Danh sách yêu thích đang trống</h3>
                        <p class="empty-desc">Hãy tìm kiếm và lưu lại những căn phòng ưng ý nhất tại House88!</p>
                        <a asp-controller="Home" asp-action="Search" class="btn-explore">
                            <i class="fa-solid fa-magnifying-glass me-2"></i>Khám phá ngay
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Favorites.css" asp-append-version="true" />
}
