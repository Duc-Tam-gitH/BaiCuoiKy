@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Quản lý người dùng";
    ViewBag.ActiveSection = "users";
}

<div class="admin-dashboard-container">
    <div class="admin-page-header">
        <h1 class="admin-page-title">Quản lý người dùng</h1>
        <p class="admin-page-subtitle">Quản lý tài khoản người dùng hệ thống</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="admin-alert admin-alert-success">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="admin-alert admin-alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["Error"]
        </div>
    }

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tên đăng nhập</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Vai trò</th>
                    <th>Số phòng trọ</th>
                    <th>Số đặt phòng</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.Users != null)
                {
                    foreach (var userViewModel in ViewBag.Users)
                    {
                        <tr>
                            <td><strong>@userViewModel.User.UserName</strong></td>
                            <td>@userViewModel.User.FullName</td>
                            <td>@userViewModel.User.Email</td>
                            <td>@userViewModel.User.PhoneNumber</td>
                            <td>
                                @foreach (var role in userViewModel.Roles)
                                {
                                    <span class="admin-badge admin-badge-primary">@role</span>
                                }
                            </td>
                            <td class="admin-text-center">@userViewModel.TotalTros</td>
                            <td class="admin-text-center">@userViewModel.TotalBookings</td>
                            <td>
                                @if (userViewModel.IsLocked)
                                {
                                    <span class="admin-badge admin-badge-danger">
                                        <i class="fas fa-lock"></i> Đã khóa
                                    </span>
                                }
                                else
                                {
                                    <span class="admin-badge admin-badge-success">
                                        <i class="fas fa-check-circle"></i> Hoạt động
                                    </span>
                                }
                            </td>
                            <td class="admin-action-buttons">
                                <a href="@Url.Action("EditUser", "Admin", new { id = userViewModel.User.Id })"
                                   class="admin-btn admin-btn-primary"
                                   title="Chỉnh sửa">
                                    <i class="fas fa-edit"></i>
                                    <span>Sửa</span>
                                </a>

                                @if (userViewModel.IsLocked)
                                {
                                    <form asp-action="UnlockUser" asp-controller="Admin" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@userViewModel.User.Id" />
                                        <button type="submit" class="admin-btn admin-btn-success" title="Mở khóa tài khoản">
                                            <i class="fas fa-unlock-alt"></i>
                                            <span>Mở khóa</span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="LockUser" asp-controller="Admin" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@userViewModel.User.Id" />
                                        <button type="submit" class="admin-btn admin-btn-warning" title="Khóa tài khoản">
                                            <i class="fas fa-lock"></i>
                                            <span>Khóa</span>
                                        </button>
                                    </form>
                                }

                                <form asp-action="Delete" asp-controller="Admin" method="post" style="display:inline"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng @userViewModel.User.UserName? Hành động này không thể hoàn tác.')">
                                    <input type="hidden" name="id" value="@userViewModel.User.Id" />
                                    <button type="submit" class="admin-btn admin-btn-danger" title="Xóa tài khoản">
                                        <i class="fas fa-trash-alt"></i>
                                        <span>Xóa</span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="admin-empty-state">
                            <i class="fas fa-users"></i>
                            <p>Không có dữ liệu người dùng</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Admin-Users.css" asp-append-version="true" />
}
