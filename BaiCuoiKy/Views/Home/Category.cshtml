@model IEnumerable<BaiCuoiKy.Models.Category>

@{
    ViewData["Title"] = "Danh mục phòng cho thuê";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h2 class="fw-bold" style="color: #002641;">Danh Mục Phòng Cho Thuê</h2>

        @* THAY ĐỔI: Chuyển thẻ <a> thành thẻ <button> để kích hoạt Modal *@
        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
            <button type="button" class="btn text-white shadow-sm" data-bs-toggle="modal" data-bs-target="#categoryModal" style="background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); border: none;">
                ⚙️ Quản lý danh mục
            </button>
        }
    </div>

    @* PHẦN HIỂN THỊ DANH MỤC CHO MỌI NGƯỜI (GIỮ NGUYÊN) *@
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <a asp-controller="Home" asp-action="Search" asp-route-loai="@item.TenDanhMuc" class="text-decoration-none">
                        <div class="card h-100 shadow-sm category-card border-0 text-center py-4">
                            <div class="card-body d-flex flex-column justify-content-center">
                                <h5 class="card-title fw-bold" style="color: #667eea;">@item.TenDanhMuc</h5>
                                @if (!string.IsNullOrEmpty(item.MoTa))
                                {
                                    <p class="text-muted small mt-2 mb-0">@item.MoTa</p>
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="display-6 text-muted">😢 Hiện chưa có danh mục nào.</p>
            </div>
        }
    </div>
</div>

@* PHẦN MỚI: MODAL QUẢN LÝ DÀNH RIÊNG CHO ADMIN *@
@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    <div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            @* Đổi thành modal-lg cho gọn vì đã bớt cột *@
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="categoryModalLabel">Quản lý Danh Mục Của Hệ Thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body bg-light">

                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="text-success mb-3 fw-bold">+ Thêm danh mục mới</h6>
                            <form asp-controller="Home" asp-action="AddCategory" method="post" class="row g-3">
                                <div class="col-md-5">
                                    <input type="text" name="TenDanhMuc" class="form-control" placeholder="Tên danh mục..." required />
                                </div>
                                <div class="col-md-5">
                                    <input type="text" name="MoTa" class="form-control" placeholder="Mô tả ngắn..." />
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-success w-100">Thêm</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th class="ps-3">Tên danh mục</th>
                                        <th>Mô tả</th>
                                        <th class="text-center">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null)
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <form asp-controller="Home" asp-action="UpdateCategory" method="post">
                                                    <input type="hidden" name="Id" value="@item.Id" />
                                                <td class="ps-3"><input type="text" name="TenDanhMuc" value="@item.TenDanhMuc" class="form-control form-control-sm" required /></td>
                                                <td><input type="text" name="MoTa" value="@item.MoTa" class="form-control form-control-sm" /></td>
                                                <td class="text-center">
                                                    <button type="submit" class="btn btn-sm btn-primary">💾 Lưu</button>
                                                    <a asp-controller="Home" asp-action="DeleteCategory" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">🗑️ Xóa</a>
                                                </td>
                                                </form>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}
}

@section Styles {
    <link rel="stylesheet" href="~/css/Category.css" asp-append-version="true" />
}