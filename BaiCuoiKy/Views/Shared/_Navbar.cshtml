﻿@using BaiCuoiKy.Models
<nav class="navbar">
    <div class="nav-left">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>

        <div class="dropdown">
            <a href="#" class="dropdown-toggle" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Danh mục
            </a>
            <ul class="dropdown-menu" aria-labelledby="categoryDropdown">

                <li>
                    <a class="dropdown-item fw-bold" style="color: #ED005A;" asp-controller="Home" asp-action="Category">
                        🌟 Xem tất cả danh mục
                    </a>
                </li>
            </ul>
        </div>

        <a asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
        <a asp-controller="Home" asp-action="Support">Hỗ trợ</a>
    </div>

    <div class="nav-right d-flex align-items-center">
        <a asp-controller="Home" asp-action="Search" class="btn btn-primary me-2">
            🔍 Tìm Kiếm
        </a>

        @if (User.Identity.IsAuthenticated)
        {
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Tro" asp-action="Create" class="btn btn-register me-2">
                    + Đăng tin
                </a>
                <a asp-controller="Khachthue" asp-action="Bookings" class="nav-link d-inline-block me-2 text-white">
                    Booking của tôi
                </a>
            }
            else
            {
                <a asp-controller="Booking" asp-action="Index" class="nav-link d-inline-block me-2 text-white">
                    Đặt phòng
                </a>
            }

            <!-- Notification Dropdown (giữ nguyên) -->
            <div class="dropdown d-inline-block me-3 notification-bell-item">
                <a class="nav-link position-relative d-flex align-items-center" href="#" id="notiDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="~/images/thongbao.png" alt="Notification" class="bell-icon-img" />

                    @if (ViewBag.NotiCount != null && ViewBag.NotiCount > 0)
                    {
                        <span class="position-absolute badge rounded-pill"
                              style="background-color: #ED005A; font-size: 0.6rem; top: -5px; right: -10px; padding: 0.35em 0.5em;">
                            @ViewBag.NotiCount
                        </span>
                    }
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 py-0 overflow-hidden" aria-labelledby="notiDropdown" style="width: 280px; border-radius: 12px;">
                    <li class="p-3 border-bottom bg-light">
                        <h6 class="mb-0 fw-bold" style="color: #002641;">Thông báo</h6>
                    </li>
                    <div class="notification-scroll" style="max-height: 250px; overflow-y: auto; overflow-x: hidden;">
                        @if (ViewBag.Notifications != null && ((List<Notification>)ViewBag.Notifications).Any())
                        {
                            @foreach (var noti in (List<Notification>)ViewBag.Notifications)
                            {
                            <li>
                                <a class="dropdown-item p-3 border-bottom small @(noti.IsRead ? "text-muted" : "fw-bold")" href="#">
                                    @noti.Message
                                    <br />
                                    <small class="text-muted" style="font-size: 0.7rem;">@noti.CreatedAt.ToString("dd/MM HH:mm")</small>
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted small">
                            <p class="mb-0">Bạn chưa có thông báo nào</p>
                        </div>
                    }
            </div>
            <li class="p-2 text-center border-top">
                <a asp-controller="Notification" asp-action="Index" class="text-decoration-none small fw-bold" style="color: #ED005A;">Xem tất cả</a>
            </li>
            </ul>
        </div>

        <!-- User Dropdown -->
        <div class="dropdown d-inline-block">
            <a class="btn btn-login dropdown-toggle" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                👤
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li><h6 class="dropdown-header">Xin chào, @User.Identity.Name</h6></li>
                <li><hr class="dropdown-divider"></li>
                @if (User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="ManageSystem">Quản trị hệ thống</a></li>
                }
                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Thông tin cá nhân</a></li>
                @if (!User.IsInRole("Admin"))
                {
                    <li><a class="dropdown-item" asp-controller="Booking" asp-action="History">Lịch sử đặt phòng</a></li>
                    <li><a class="dropdown-item" asp-controller="Khachthue" asp-action="Favorites">Phòng yêu thích</a></li>
                }
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                    </form>
                </li>
            </ul>
        </div>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-login me-2">Đăng nhập</a>
        <a asp-controller="Account" asp-action="Register" class="btn btn-register">Đăng ký</a>
    }
    </div>
</nav>