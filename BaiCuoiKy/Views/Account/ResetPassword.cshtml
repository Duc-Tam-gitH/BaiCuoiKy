@{
}
@model BaiCuoiKy.Models.ViewModel.ResetPasswordViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h2 class="fw-bold text-center mb-4" style="color: #002641;">Thiết lập mật khẩu mới</h2>

                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input asp-for="Password" class="form-control rounded-pill px-4" type="password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-pill px-4" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn w-100 rounded-pill text-white fw-bold py-2 shadow-sm"
                            style="background: linear-gradient(135deg, #ED005A 0%, #c4004b 100%); border: none;">
                        Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>