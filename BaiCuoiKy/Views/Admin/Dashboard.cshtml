@using BaiCuoiKy.Models.ViewModel
@model DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.ActiveSection = Model.ActiveSection;
}

<div class="page-header">
    <h1 class="page-title">
        @switch (Model.ActiveSection)
        {
            case "overview":
                @:Tổng quan
                break;
            case "rooms":
                @:Quản lý phòng trọ
                break;
            case "bookings":
                @:Duyệt đơn đặt phòng
                break;
            case "users":
                @:Quản lý người dùng
                break;
            case "settings":
                @:Cài đặt hệ thống
                break;
            default:
                @:Tổng quan
                break;
        }
    </h1>
    <p class="page-desc">
        @switch (Model.ActiveSection)
        {
            case "overview":
                @:Thống kê toàn cảnh và hoạt động gần đây của hệ thống.
                break;
            case "rooms":
                @:Danh sách, tình trạng và thông tin phòng trọ.
                break;
            case "bookings":
                @:Quản lý và xét duyệt các yêu cầu đặt phòng từ khách hàng.
                break;
            case "users":
                @:Quản lý tài khoản người dùng hệ thống.
                break;
            case "settings":
                @:Cấu hình chung, bảo mật và tùy chỉnh nền tảng.
                break;
        }
    </p>
</div>

<div id="contentRenderer">
    @if (Model.ActiveSection == "overview" || string.IsNullOrEmpty(Model.ActiveSection))
    {
        await Html.RenderPartialAsync("_Overview", Model);
    }
    else if (Model.ActiveSection == "rooms")
    {
        await Html.RenderPartialAsync("_Rooms", Model);
    }
    else if (Model.ActiveSection == "bookings")
    {
        await Html.RenderPartialAsync("_Bookings", Model);
    }
    else if (Model.ActiveSection == "users")
    {
        await Html.RenderPartialAsync("Users", Model);
    }
    else if (Model.ActiveSection == "settings")
    {
        await Html.RenderPartialAsync("_Settings");
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xử lý khi chuyển section bằng AJAX nếu cần
            $('.nav-item').click(function(e) {
                var section = $(this).data('section');
                if (section && window.location.pathname.includes('Dashboard')) {
                    e.preventDefault();
                    // Có thể load nội dung bằng AJAX ở đây
                    window.location.href = '?section=' + section;
                }
            });
        });
    </script>
}