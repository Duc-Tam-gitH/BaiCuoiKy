@model BaiCuoiKy.Models.Tro
@{
    var isAdmin = ViewBag.IsAdmin == true;
    var isOwner = ViewBag.IsOwner == true;
    var canEdit = ViewBag.CanEdit == true;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;

    Layout = isAdmin ? "_AdminLayout" : "_Layout";
    ViewBag.Title = Model.TieuDe;

    if (isAdmin)
    {
        ViewBag.ActiveSection = "rooms";
    }
}

<div class="room-detail-container">
    <div class="container-fluid px-0">
        <nav aria-label="breadcrumb" class="bg-light py-2 px-3 rounded">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Home")">
                        <i class="fas fa-home"></i> Trang chủ
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Tro")">Phòng trọ</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
            </ol>
        </nav>
    </div>

    <div class="row mt-4">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body p-0">
                    @if (Model.AnhPhongs != null && Model.AnhPhongs.Any())
                    {
                        var mainImage = Model.AnhPhongs.First().Url;
                        var otherImages = Model.AnhPhongs.Skip(1).ToList();

                        <div class="room-gallery">
                            <div class="main-image">
                                <img id="mainRoomImage" src="@mainImage" alt="@Model.TieuDe" onclick="showImageModal('@mainImage')" />
                            </div>
                            @if (otherImages.Any())
                            {
                                <div class="thumbnail-list">
                                    @foreach (var img in otherImages)
                                    {
                                        <div class="thumbnail-item" onclick="changeMainImage('@img.Url')">
                                            <img src="@img.Url" alt="Thumbnail" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="no-image-placeholder text-center py-5">
                            <i class="fas fa-image fa-4x text-muted mb-3"></i>
                            <p class="text-muted">Chưa có hình ảnh</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="room-title">@Model.TieuDe</h2>

                    <div class="room-location mb-3">
                        <i class="fas fa-map-marker-alt text-danger"></i>
                        <span>@Model.DiaChi</span>
                    </div>

                    <div class="room-price mb-4">
                        <span class="price-value">@((Model.Gia).ToString("N0")) VNĐ</span>
                        <span class="price-unit">/ tháng</span>
                    </div>

                    <div class="room-info-grid mb-4">
                        <div class="info-item">
                            <div class="info-icon">
                                <i class="fas fa-ruler-combined"></i>
                            </div>
                            <div class="info-text">
                                <span class="info-label">Diện tích</span>
                                <span class="info-value">@Model.DienTich m²</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon">
                                <i class="fas fa-tag"></i>
                            </div>
                            <div class="info-text">
                                <span class="info-label">Danh mục</span>
                                <span class="info-value">@(Model.Category?.TenDanhMuc ?? "Chưa phân loại")</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div class="info-text">
                                <span class="info-label">Ngày đăng</span>
                                <span class="info-value">@Model.NgayDang.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-icon">
                                <i class="fas fa-eye"></i>
                            </div>
                            <div class="info-text">
                                <span class="info-label">Lượt xem</span>
                                <span class="info-value">@(Model.ViewCount ?? 0)</span>
                            </div>
                        </div>
                    </div>

                    <div class="room-description">
                        <h5><i class="fas fa-align-left me-2"></i> Mô tả chi tiết</h5>
                        <div class="description-content">
                            @Html.Raw(Model.MoTa?.Replace("\n", "<br />"))
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h4 class="fw-bold" style="color: #003366;">
                        <i class="fas fa-comments me-2"></i> Đánh giá từ khách thuê (@(Model.Reviews?.Count(r => !r.IsHidden) ?? 0))
                    </h4>
                    <hr />

                    @if (isAdmin)
                    {
                        <div class="alert alert-info shadow-sm border-0 mb-4">
                            <i class="fas fa-user-shield me-2"></i> Bạn đang đăng nhập dưới quyền <strong>Quản trị viên</strong>. Bạn chỉ có quyền kiểm duyệt bình luận, không thể tự thêm đánh giá mới.
                        </div>
                    }
                    else if (isAuthenticated)
                    {
                        <div class="mb-4 p-3 rounded" style="background-color: #f8f9fa;">
                            <h6 class="fw-bold mb-3">Để lại ý kiến của bạn</h6>
                            <form asp-controller="Home" asp-action="PostReview" method="post">
                                <input type="hidden" name="TroId" value="@Model.Id" />

                                <div class="mb-3" style="width: 250px;">
                                    <select name="Rating" class="form-select border-primary">
                                        <option value="5">⭐⭐⭐⭐⭐ (Tuyệt vời)</option>
                                        <option value="4">⭐⭐⭐⭐ (Tốt)</option>
                                        <option value="3">⭐⭐⭐ (Bình thường)</option>
                                        <option value="2">⭐⭐ (Kém)</option>
                                        <option value="1">⭐ (Rất tệ)</option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <textarea name="Comment" class="form-control" rows="3" placeholder="Chia sẻ trải nghiệm của bạn về phòng trọ này..." required></textarea>
                                </div>

                                <button type="submit" class="btn btn-primary px-4 rounded-pill">Gửi đánh giá</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning shadow-sm border-0">
                            Vui lòng <a href="/Account/Login" class="fw-bold text-danger">đăng nhập</a> để có thể bình luận và đánh giá phòng trọ này.
                        </div>
                    }
                    <div class="review-list mt-4">
                        @{
                            // 🔥 LOGIC MỚI: Admin thấy tất cả, Khách thường chỉ thấy bình luận không bị ẩn
                            var displayReviews = isAdmin ? Model.Reviews : Model.Reviews?.Where(r => !r.IsHidden);
                        }

                        @if (displayReviews != null && displayReviews.Any())
                        {
                            foreach (var review in displayReviews.OrderByDescending(r => r.NgayDanhGia))
                            {
                                <div class="d-flex mb-4 border-bottom pb-3">
                                    <div class="me-3">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fs-5 fw-bold" style="width: 50px; height: 50px;">
                                            @(review.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                        </div>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-0 fw-bold">
                                                    @review.User?.UserName
                                                    @if (review.IsHidden)
                                                    {
                                                        <span class="badge bg-secondary ms-2" style="font-size: 0.7em;">Đã ẩn</span>
                                                    }
                                                </h6>
                                                <small class="text-muted">@review.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>

                                            @if (isAdmin)
                                            {
                                                <div>
                                                    <a href="@Url.Action("ToggleReview", "Admin", new { id = review.Id })" class="btn btn-sm btn-outline-warning" title="Ẩn/Hiện bình luận">
                                                        <i class="fas @(review.IsHidden ? "fa-eye" : "fa-eye-slash")"></i>
                                                    </a>
                                                    <a href="@Url.Action("DeleteReview", "Admin", new { id = review.Id })" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa vĩnh viễn bình luận này?');" title="Xóa bình luận">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </a>
                                                </div>
                                            }
                                        </div>
                                        <div class="text-warning my-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas @(i <= review.Rating ? "fa-star" : "fa-star text-light")"></i>
                                            }
                                        </div>
                                        <p class="mb-0 @(review.IsHidden ? "text-muted fst-italic" : "text-dark")">@review.Comment</p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted my-5">
                                <i class="fas fa-comment-slash fa-3x mb-3 text-light"></i>
                                <p>Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá phòng trọ này!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i> Thông tin chủ trọ
                    </h5>
                </div>
                <div class="card-body">
                    <div class="owner-info text-center">
                        <div class="owner-avatar-large mb-3">
                            @{
                                var initials = GetInitials(Model.User?.FullName ?? Model.User?.UserName);
                            }
                            <div class="avatar-circle-large">@initials</div>
                        </div>
                        <h5 class="owner-name">@(Model.User?.FullName ?? Model.User?.UserName)</h5>
                        <p class="owner-email">
                            <i class="fas fa-envelope me-1"></i> @Model.User?.Email
                        </p>
                        <p class="owner-phone">
                            <i class="fas fa-phone me-1"></i> @(Model.User?.PhoneNumber ?? "Chưa cập nhật")
                        </p>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-hand-pointer me-2"></i> Hành động
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.TrangThai != TrangThaiPhong.DaChoThue)
                    {
                        @if (isAuthenticated)
                        {
                            <button type="button" class="btn btn-primary w-100 mb-2" onclick="contactOwner()">
                                <i class="fas fa-phone-alt me-2"></i> Liên hệ chủ trọ
                            </button>

                            <form asp-controller="Tro" asp-action="BookRoom" method="post">
                                <input type="hidden" name="troId" value="@Model.Id" />
                                <button type="submit" class="btn btn-outline-success w-100 mb-2"
                                        onclick="return confirm('Xác nhận: Bạn muốn gửi yêu cầu đặt phòng này? Cọc phí dự kiến là 20% giá trị phòng.');">
                                    <i class="fas fa-calendar-check me-2"></i> Đặt phòng ngay
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                Vui lòng <a href="@Url.Action("Login", "Account")?returnUrl=@Context.Request.Path">đăng nhập</a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-danger text-center">
                            <i class="fas fa-times-circle me-2"></i>
                            Phòng đã được thuê
                        </div>
                    }

                    @if (canEdit)
                    {
                        <hr />
                        <div class="admin-actions">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-cog me-1"></i> Quản lý bài đăng
                            </h6>

                            <a href="@Url.Action("Edit", "Tro", new { id = Model.Id })" class="btn btn-warning w-100 mb-2">
                                <i class="fas fa-edit me-2"></i> Chỉnh sửa
                            </a>

                            @if (isAdmin)
                            {
                                <button type="button" class="btn btn-outline-danger w-100 mb-2"
                                        onclick="deleteRoom(@Model.Id, '@Model.TieuDe')">
                                    <i class="fas fa-trash-alt me-2"></i> Xóa
                                </button>

                                <select class="form-select" onchange="updateStatus(@Model.Id, this.value)">
                                    <option value="0" selected="@(Model.TrangThai == TrangThaiPhong.DangTrong)">Đang trống</option>
                                    <option value="1" selected="@(Model.TrangThai == TrangThaiPhong.DangXuLy)">Đang xử lý</option>
                                    <option value="2" selected="@(Model.TrangThai == TrangThaiPhong.DaChoThue)">Đã cho thuê</option>
                                </select>
                            }
                        </div>
                    }
                </div>
            </div>

            @if (isAdmin)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-chart-line me-2"></i> Thống kê & Quản trị
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="admin-stats">
                            <div class="stat-row">
                                <span><i class="fas fa-calendar-check"></i> Tổng đặt phòng:</span>
                                <strong>@(Model.Bookings?.Count ?? 0)</strong>
                            </div>
                            <div class="stat-row">
                                <span><i class="fas fa-id-card"></i> Mã phòng:</span>
                                <strong>#@Model.Id</strong>
                            </div>
                            <div class="stat-row">
                                <span><i class="fas fa-user"></i> Mã chủ trọ:</span>
                                <strong>@Model.UserId</strong>
                            </div>
                        </div>
                        <hr />
                        <div class="admin-status-actions">
                            <label class="fw-bold mb-2">Cập nhật trạng thái:</label>
                            <div class="admin-status-actions">
                                <label class="fw-bold mb-2">Cập nhật trạng thái:</label>

                                <select class="form-select" onchange="updateStatus(@Model.Id, this.value)">
                                    <option value="0" selected="@(Model.TrangThai == TrangThaiPhong.DangTrong)">
                                        Đang trống
                                    </option>
                                    <option value="1" selected="@(Model.TrangThai == TrangThaiPhong.DangXuLy)">
                                        Đang xử lý
                                    </option>
                                    <option value="2" selected="@(Model.TrangThai == TrangThaiPhong.DaChoThue)">
                                        Đã cho thuê
                                    </option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Hình ảnh phòng trọ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" alt="Room image" style="max-width: 100%; max-height: 70vh;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Details.js"></script>
    @functions {
    string GetInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "A";
        var parts = name.Trim().Split(' ');
        if (parts.Length >= 2)
            return parts[0][0].ToString().ToUpper() + parts[1][0].ToString().ToUpper();
        return name[0].ToString().ToUpper();
    }
}
}

@section Styles {
    <link rel="stylesheet" href="~/css/Details.css" asp-append-version="true" />
}