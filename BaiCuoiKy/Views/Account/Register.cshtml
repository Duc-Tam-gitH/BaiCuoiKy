@model BaiCuoiKy.Models.ViewModel.RegisterViewModel
@{
    Layout = null;
}
<link rel="stylesheet" href="~/css/auth.css" />

<div class="auth-wrapper">

    <div class="auth-card">

        <!-- LEFT IMAGE -->
        <div class="auth-left">
            <div class="auth-logo">Shopping</div>
        </div>

        <!-- RIGHT FORM -->
        <div class="auth-right">

            <h2>Đăng ký</h2>

            <p>
                Nếu bạn đã có tài khoản,
                <a asp-action="Login">đăng nhập</a>
            </p>

            <form asp-action="Register">

                <input asp-for="Email"
                       class="auth-input"
                       placeholder="Email" />

                <input asp-for="Password"
                       type="password"
                       class="auth-input"
                       placeholder="Mật khẩu" />

                <input asp-for="ConfirmPassword"
                       type="password"
                       class="auth-input"
                       placeholder="Nhập lại mật khẩu" />

                <button class="auth-btn">
                    Đăng ký
                </button>

            </form>

        </div>

    </div>

</div>