@model List<Tro>
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<div class="home-container">

    <!-- HERO -->
    <div class="hero">
        <h1>Tìm Phòng Trọ & Nhà Cho Thuê</h1>
        <p>Nhanh Chóng - An Toàn - Tiện Lợi</p>

        <!-- SEARCH -->
        <form asp-controller="Tro" asp-action="Search" method="get" class="search-box">
            <select name="khuvuc">
                <option value="">Khu vực</option>
            </select>

            <select name="loai">
                <option value="">Loại hình</option>
            </select>

            <select name="gia">
                <option value="">Giá</option>
            </select>

            <input type="text" name="keyword" placeholder="Tìm kiếm..." />
            <button type="submit">Tìm Kiếm</button>
        </form>
    </div>

    <!-- PHÒNG -->
    <div class="section">
        <h2>Phòng Trọ Nổi Bật</h2>

        <div class="room-list">

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    var img = item.AnhPhongs != null && item.AnhPhongs.Any()
                    ? item.AnhPhongs.First().Url
                    : "/images/no-image.jpg";

                    <a asp-controller="Tro" asp-action="Details" asp-route-id="@item.Id">
                        <div class="room-card">
                            <img src="@img" loading="lazy" />

                            <h3>@item.TieuDe</h3>

                            <p class="price">
                                @String.Format("{0:N0} VNĐ", item.Gia)
                            </p>

                            <p>@item.DiaChi</p>
                        </div>
                    </a>
                }
            }
            else
            {
                <p>Không có phòng nào</p>
            }

        </div>
    </div>

    <!-- LOẠI -->
    <div class="section">
        <h2>Tìm Theo Loại Hình</h2>

        <div class="category-list">
            <div class="category">Phòng Trọ</div>
            <div class="category">Căn Hộ Mini</div>
            <div class="category">Nhà Nguyên Căn</div>
            <div class="category">Ký Túc Xá</div>
        </div>
    </div>

    <!-- CTA -->
    <div class="cta">
        <h2>Đăng Tin Cho Thuê Ngay!</h2>

        <a asp-controller="Tro" asp-action="Create" class="btn btn-warning">
            Đăng Tin Ngay
        </a>
    </div>

</div>