@{
    Layout = null;
    var userInitials = ViewBag.UserInitials ?? "AD";
    var userName = ViewBag.UserName ?? "Administrator";
    var userRole = ViewBag.UserRole ?? "Admin";
    var activeSection = ViewBag.ActiveSection ?? "overview";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Quản lý hệ thống - @ViewBag.Title</title>

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- Admin Custom CSS -->
    <link rel="stylesheet" href="~/css/admin.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Mobile Menu Toggle Button -->
    <button class="admin-menu-toggle" id="menuToggle">
        <i class="fas fa-bars"></i>
    </button>

    <div class="admin-app-container">
        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div>
                <div class="admin-logo-area">
                    <div class="admin-logo">Quản Lý<span>HệThống</span></div>
                </div>
                <div class="admin-nav-menu">
                    <a asp-controller="Home" asp-action="Index" class="admin-nav-item">
                        <i class="fas fa-home"></i>
                        <span>Trang chủ</span>
                    </a>
                    <a href="@Url.Action("Dashboard", "Admin", new { section = "overview" })" class="admin-nav-item @(activeSection == "overview" ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Tổng quan</span>
                    </a>
                    <a href="@Url.Action("Dashboard", "Admin", new { section = "rooms" })" class="admin-nav-item @(activeSection == "rooms" ? "active" : "")">
                        <i class="fas fa-building"></i>
                        <span>Phòng trọ</span>
                    </a>
                    <a href="@Url.Action("Dashboard", "Admin", new { section = "users" })" class="admin-nav-item @(activeSection == "users" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Người dùng</span>
                    </a>
                    <div class="admin-section-divider"></div>
                    <a href="@Url.Action("Dashboard", "Admin", new { section = "settings" })" class="admin-nav-item @(activeSection == "settings" ? "active" : "")">
                        <i class="fas fa-sliders-h"></i>
                        <span>Cài đặt</span>
                    </a>
                </div>
            </div>

            <div class="admin-user-footer">
                <div class="admin-user-info">
                    <div class="admin-avatar-circle">@userInitials</div>
                    <div class="admin-user-details">
                        <div class="admin-user-name">@userName</div>
                        <div class="admin-user-role">@userRole</div>
                    </div>
                </div>
                <div class="admin-logout-icon" id="logoutButton">
                    <i class="fas fa-sign-out-alt"></i>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main-content">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Xử lý logout
        $('#logoutButton').click(function() {
            if (confirm('Bạn có chắc chắn muốn đăng xuất?')) {
                $.post('@Url.Action("Logout", "Account")', function() {
                    window.location.href = '@Url.Action("Index", "Home")';
                });
            }
        });

        // Xử lý menu toggle cho mobile
        $('#menuToggle').click(function() {
            $('#adminSidebar').toggleClass('open');
        });

        // Đóng menu khi click ra ngoài trên mobile
        $(document).click(function(event) {
            if ($(window).width() <= 768) {
                if (!$(event.target).closest('#adminSidebar').length &&
                    !$(event.target).closest('#menuToggle').length) {
                    $('#adminSidebar').removeClass('open');
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>