@model List<BaiCuoiKy.Models.Booking>

@{
    ViewData["Title"] = "Quản lý Đặt phòng";
    Layout = "_Layout";
}

<div class="container py-5" style="min-height: 75vh;">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow" style="width: 50px; height: 50px; background-color: #002b49 !important;">
            <i class="fas fa-calendar-check fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0" style="color: #002b49;">Danh sách phòng đã đặt</h2>
            <p class="text-muted mb-0">Theo dõi trạng thái các yêu cầu thuê phòng của bạn</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light" style="color: #002b49;">
                        <tr>
                            <th class="py-3 px-4">Tên phòng</th>
                            <th class="py-3">Ngày đặt</th>
                            <th class="py-3">Ngày nhận</th>
                            <th class="py-3 text-end">Tiền cọc (20%)</th>
                            <th class="py-3 text-center">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-bold text-primary">
                                    <a href="/Tro/Details/@item.TroId" class="text-decoration-none">
                                        @(item.Tro?.TieuDe ?? "Phòng không tồn tại")
                                    </a>
                                </td>
                                <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.NgayNhan.ToString("dd/MM/yyyy")</td>
                                <td class="text-end fw-bold text-danger">
                                    @item.TienCoc.ToString("N0") VNĐ
                                </td>
                                <td class="text-center">
                                    @if (item.TrangThai == "ChoDuyet")
                                    {
                                        <span class="badge bg-warning text-dark py-2 px-3 rounded-pill">Chờ duyệt</span>
                                    }
                                    else if (item.TrangThai == "ChoThanhToan")
                                    {
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <span class="badge bg-info text-dark py-2 px-3 rounded-pill">Chờ cọc</span>
                                            <button class="btn btn-sm btn-danger rounded-pill px-3 shadow-sm"
                                                    onclick="openPaymentModal('@item.Id', '@item.TienCoc', '@item.Tro?.TieuDe')">
                                                <i class="fas fa-qrcode me-1"></i> Thanh toán
                                            </button>
                                        </div>
                                    }
                                    else if (item.TrangThai == "ChoXacNhan")
                                    {
                                        <span class="badge bg-primary py-2 px-3 rounded-pill">Chờ xác nhận tiền</span>
                                    }
                                    else if (item.TrangThai == "ChoXacNhanTraPhong")
                                    {
                                        <span class="badge bg-secondary py-2 px-3 rounded-pill">Chờ duyệt trả phòng</span>
                                    }
                                    else if (item.TrangThai == "HoanTat")
                                    {
                                        <div class="d-flex flex-column align-items-center gap-2">
                                            <span class="badge bg-success py-2 px-3 rounded-pill">Đang thuê</span>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm"
                                                    onclick="openCheckoutModal('@item.Id', '@item.NgayNhan.ToString("yyyy-MM-dd")', '@item.Tro?.TieuDe')">
                                                <i class="fas fa-sign-out-alt me-1"></i> Trả phòng
                                            </button>
                                        </div>
                                    }
                                    else if (item.TrangThai == "DaTraPhong")
                                    {
                                        <div class="text-center">
                                            <span class="badge bg-dark py-2 px-3 rounded-pill">Đã trả phòng</span>
                                            <p class="small text-muted mt-1 mb-0"><i class="fas fa-heart text-danger"></i> Cảm ơn bạn!</p>
                                        </div>
                                    }
                                    else if (item.TrangThai == "DaHuy")
                                    {
                                        <span class="badge bg-danger py-2 px-3 rounded-pill">Đã hủy</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-center py-5">
                <i class="far fa-calendar-times fa-4x text-muted mb-4" style="opacity: 0.3;"></i>
                <h5 class="fw-bold text-secondary">Bạn chưa đặt phòng nào</h5>
                <a href="/" class="btn btn-outline-primary rounded-pill px-4 mt-2">Tìm phòng ngay</a>
            </div>
        }
    </div>
</div>

@* Modal Thanh Toán *@
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <i class="fas fa-shield-alt text-success fa-3x mb-3"></i>
                <h4 class="fw-bold mb-1" style="color: #002b49;">Thanh toán tiền cọc</h4>
                <p class="text-muted small mb-4" id="roomNameDisplay"></p>
                <div class="bg-white p-2 rounded-4 mb-3 d-inline-block border shadow-sm">
                    <img id="qrImage" src="~/images/QR.jpg" alt="QR Payment MB Bank" class="img-fluid" style="max-width: 220px;">
                </div>
                <div class="alert alert-warning border-0 small py-2">
                    Số tiền: <strong id="amountDisplay" class="text-danger"></strong>
                </div>
                <form asp-controller="Khachthue" asp-action="ConfirmPayment" method="post">
                    <input type="hidden" name="bookingId" id="bookingIdInput" />
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow">Tôi đã chuyển khoản</button>
                </form>
            </div>
        </div>
    </div>
</div>

@* Modal Trả Phòng *@
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title fw-bold"><i class="fas fa-door-open me-2"></i> Xác nhận Trả phòng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Khachthue" asp-action="ConfirmCheckout" method="post">
                <div class="modal-body">
                    <input type="hidden" name="bookingId" id="checkoutBookingId" />
                    <input type="hidden" id="checkinDateHidden" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Phòng đang thuê:</label>
                        <p id="checkoutRoomName" class="text-primary fw-bold mb-0"></p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngày trả phòng thực tế:</label>
                        <input type="date" name="NgayTra" id="checkoutDateInput" class="form-control" required onchange="checkStayDuration()" />
                    </div>

                    <div id="checkoutNotice" class="alert d-none"></div>

                    <div class="alert alert-secondary small py-2 mb-0">
                        <i class="fas fa-info-circle me-1"></i> Lưu ý: Tiền cọc sẽ được hoàn trả (nếu đủ điều kiện) sau khi Admin kiểm tra phòng.
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow">Gửi yêu cầu trả phòng</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles{
    <link rel="stylesheet" href="~/css/Bookings.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/KTBooking.js"></script>
}