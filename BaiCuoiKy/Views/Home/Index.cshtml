@using BaiCuoiKy.Models
@model IEnumerable<BaiCuoiKy.Models.Tro>

@{
    ViewData["Title"] = "Trang Chủ - Thuê Phòng";
}

@section Styles {
    <link rel="stylesheet" href="~/css/House88.css" asp-append-version="true" />
}

<div class="home-container">

    <section class="hero">
        <h1>Tìm Phòng Trọ & Nhà Cho Thuê</h1>
        <p>Nhanh Chóng - An Toàn - Tiện Lợi</p>


        <div class="container">
        
        @* Lưu ý: Nếu chưa có TroController, hãy đổi asp-controller="Home" *@
            <form asp-controller="Home" asp-action="Search" method="get" class="search-box">
            <select name="khuvuc" class="form-select w-auto">
                <option value="">Khu vực</option>
                <option>Hồ Chí Minh</option>
                <option>Hà Nội</option>
                <option>Đà Nẵng</option>
            </select>

            <select name="loai" class="form-select w-auto">
                <option value="">Loại hình</option>
                <option>Phòng trọ</option>
                <option>Căn hộ mini</option>
                <option>Nhà nguyên căn</option>
            </select>

            <select name="gia" class="form-select w-auto">
                <option value="">Giá</option>
                <option value="1">Dưới 2 triệu</option>
                <option value="2">2 - 5 triệu</option>
                <option value="3">Trên 5 triệu</option>
            </select>

            <input type="text" name="keyword" class="form-control w-auto" placeholder="Nhập từ khóa..." />

            <button type="submit" class="btn btn-primary">
                🔍 Tìm Kiếm
            </button>
        </form>
        </div>
    </section>

    <section class="container mt-5">
        <div class="section-header mb-4">
            <h2>Phòng Trọ Nổi Bật</h2>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    // Logic lấy ảnh: Kiểm tra list AnhPhongs từ Model Tro.cs
                    var img = (item.AnhPhongs != null && item.AnhPhongs.Any())
                    ? item.AnhPhongs.First().Url
                    : "/images/favicon.ico"; // Tạm thời dùng favicon nếu chưa có ảnh no-image

                    <div class="col-md-4">
                        <a asp-controller="Tro" asp-action="Details" asp-route-id="@item.Id" class="room-link">
                            <div class="room-card">
                                <div class="room-img">
                                    <img src="@img" alt="@item.TieuDe" loading="lazy" />
                                </div>
                                <div class="room-body mt-2">
                                    <h3 class="room-title h5">@item.TieuDe</h3>
                                    <p class="price text-danger fw-bold">
                                        @String.Format("{0:N0} VNĐ", item.Gia)
                                    </p>
                                    <p class="location small text-muted">
                                        📍 @item.DiaChi
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="display-6">😢 Hiện chưa có phòng nào</p>
                </div>
            }
        </div>
    </section>

    <section class="container mt-5 text-center">
        <h2 class="mb-4">Tin tức </h2>
    </section>

    <section class="cta bg-primary text-white text-center py-5 mt-5 rounded">
        <h2>Đăng Tin Cho Thuê Ngay!</h2>
        <p>Tiếp cận hàng ngàn khách hàng tiềm năng mỗi ngày</p>
        <a asp-controller="Tro" asp-action="Create" class="btn btn-light btn-lg mt-3">
            🚀 Đăng Tin Ngay
        </a>
    </section>

</div>