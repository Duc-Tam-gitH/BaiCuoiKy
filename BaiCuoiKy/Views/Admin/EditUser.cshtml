@model BaiCuoiKy.Models.ViewModel.EditUserViewModel
@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Chỉnh sửa người dùng";
    ViewBag.ActiveSection = "users";
}

<div class="admin-edit-container">
    <div class="admin-page-header">
        <div class="admin-header-left">
            <a href="@Url.Action("Dashboard", "Admin", new { section = "users" })" class="admin-back-btn">
                <i class="fas fa-arrow-left"></i>
                <span>Quay lại</span>
            </a>
            <h1 class="admin-page-title">Chỉnh sửa người dùng</h1>
            <p class="admin-page-subtitle">Cập nhật thông tin và quyền truy cập cho tài khoản</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="admin-alert admin-alert-success">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="admin-alert admin-alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["Error"]
        </div>
    }

    <form asp-action="Edit" method="post" class="admin-edit-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="admin-form-grid">
            <!-- Thông tin cá nhân -->
            <div class="admin-form-card">
                <div class="admin-card-header">
                    <div class="admin-card-icon">
                        <i class="fas fa-user-circle"></i>
                    </div>
                    <h3 class="admin-card-title">Thông tin cá nhân</h3>
                </div>

                <div class="admin-card-body">
                    <div class="admin-form-group">
                        <label asp-for="UserName" class="admin-form-label">
                            <i class="fas fa-user"></i>
                            <span>Tên đăng nhập</span>
                        </label>
                        <input asp-for="UserName" class="admin-form-control" placeholder="Nhập tên đăng nhập" />
                        <span asp-validation-for="UserName" class="admin-validation-error"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="FullName" class="admin-form-label">
                            <i class="fas fa-user-tag"></i>
                            <span>Họ và tên</span>
                        </label>
                        <input asp-for="FullName" class="admin-form-control" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="admin-validation-error"></span>
                    </div>

                    <div class="admin-form-group">
                        <label asp-for="Email" class="admin-form-label">
                            <i class="fas fa-envelope"></i>
                            <span>Email</span>
                        </label>
                        <input asp-for="Email" class="admin-form-control" placeholder="example@email.com" />
                        <span asp-validation-for="Email" class="admin-validation-error"></span>
                    </div>

                    <div class="admin-form-row">
                        <div class="admin-form-group admin-form-group-half">
                            <label asp-for="PhoneNumber" class="admin-form-label">
                                <i class="fas fa-phone"></i>
                                <span>Số điện thoại</span>
                            </label>
                            <input asp-for="PhoneNumber" class="admin-form-control" placeholder="0123456789" />
                            <span asp-validation-for="PhoneNumber" class="admin-validation-error"></span>
                        </div>

                        <div class="admin-form-group admin-form-group-half">
                            <label asp-for="Address" class="admin-form-label">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>Địa chỉ</span>
                            </label>
                            <input asp-for="Address" class="admin-form-control" placeholder="Nhập địa chỉ" />
                            <span asp-validation-for="Address" class="admin-validation-error"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quản lý tài khoản -->
            <div class="admin-form-card">
                <div class="admin-card-header">
                    <div class="admin-card-icon">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h3 class="admin-card-title">Quản lý tài khoản</h3>
                </div>

                <div class="admin-card-body">
                    <div class="admin-toggle-group">
                        <div class="admin-toggle-item">
                            <div class="admin-toggle-info">
                                <i class="fas fa-lock"></i>
                                <div>
                                    <h4>Khóa tài khoản</h4>
                                    <p>Người dùng sẽ không thể đăng nhập khi tài khoản bị khóa</p>
                                </div>
                            </div>
                            <label class="admin-switch">
                                <input type="checkbox" asp-for="IsLocked" />
                                <span class="admin-switch-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phân quyền -->
            <div class="admin-form-card">
                <div class="admin-card-header">
                    <div class="admin-card-icon">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <h3 class="admin-card-title">Phân quyền người dùng</h3>
                    <p class="admin-card-subtitle">Chọn vai trò cho tài khoản này</p>
                </div>

                <div class="admin-card-body">
                    <div class="admin-roles-grid">
                        @if (Model.Roles != null)
                        {
                            foreach (var role in Model.Roles)
                            {
                                bool isChecked = Model.UserRoles != null && Model.UserRoles.Contains(role);
                                <label class="admin-role-card @(isChecked ? "active" : "")">
                                    <input type="checkbox"
                                           name="SelectedRoles"
                                           value="@role"
                                           @(isChecked ? "checked" : "") />
                                    <div class="admin-role-content">
                                        <div class="admin-role-icon">
                                            @if (role == "Admin")
                                            {
                                                <i class="fas fa-crown"></i>
                                            }
                                            else if (role == "Landlord")
                                            {
                                                <i class="fas fa-building"></i>
                                            }
                                            else if (role == "Tenant")
                                            {
                                                <i class="fas fa-home"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-user"></i>
                                            }
                                        </div>
                                        <div class="admin-role-info">
                                            <h4>@role</h4>
                                            <p>
                                                @if (role == "Admin")
                                                {
                                                    <span>Quyền quản trị hệ thống</span>
                                                }
                                                else if (role == "Landlord")
                                                {
                                                    <span>Quyền đăng tin cho thuê</span>
                                                }
                                                else if (role == "Tenant")
                                                {
                                                    <span>Quyền thuê phòng trọ</span>
                                                }
                                                else
                                                {
                                                    <span>Quyền truy cập cơ bản</span>
                                                }
                                            </p>
                                        </div>
                                        <div class="admin-role-check">
                                            <i class="fas fa-check-circle"></i>
                                        </div>
                                    </div>
                                </label>
                            }
                        }
                    </div>
                    <div asp-validation-summary="All" class="admin-validation-summary"></div>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="admin-form-actions">
            <a href="@Url.Action("Dashboard", "Admin", new { section = "users" })" class="admin-btn admin-btn-secondary">
                <i class="fas fa-times"></i>
                <span>Hủy bỏ</span>
            </a>
            <button type="submit" class="admin-btn admin-btn-primary">
                <i class="fas fa-save"></i>
                <span>Lưu thay đổi</span>
            </button>
        </div>
    </form>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/Admin-EditUser.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/Admin-EditUsers.js"></script>
}