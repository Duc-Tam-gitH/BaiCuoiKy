@{
}
@model BaiCuoiKy.Models.ViewModel.ForgotPasswordViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h2 class="fw-bold text-center mb-4" style="color: #002641;">Quên mật khẩu?</h2>
                <p class="text-muted text-center mb-4">Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email của bạn</label>
                        <input asp-for="Email" class="form-control rounded-pill px-4" placeholder="name@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn w-100 rounded-pill text-white fw-bold py-2 shadow-sm"
                            style="background: linear-gradient(135deg, #ED005A 0%, #c4004b 100%); border: none;">
                        Gửi yêu cầu
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="Login" class="text-decoration-none small" style="color: #002641;">Quay lại Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>
