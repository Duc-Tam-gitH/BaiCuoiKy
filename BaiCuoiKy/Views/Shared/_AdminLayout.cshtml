@using Microsoft.AspNetCore.Identity
@using BaiCuoiKy.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    Layout = null;
    var currentUser = await UserManager.GetUserAsync(User);
    var userRoles = await UserManager.GetRolesAsync(currentUser);
    var initials = GetInitials(currentUser?.FullName ?? currentUser?.UserName ?? "User");
}

@functions {
    string GetInitials(string fullName)
    {
        if (string.IsNullOrEmpty(fullName)) return "U";
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Quản lý hệ thống | @ViewBag.Title</title>

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <!-- Custom CSS -->
    <link href="~/css/admin.css" rel="stylesheet" />
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div>
                <div class="logo-area">
                    <div class="logo">QL<span>HệThống</span></div>
                </div>
                <div class="nav-menu">
                    <a asp-action="Dashboard" asp-controller="Admin" asp-route-section="overview" class="nav-item @(ViewBag.ActiveSection == "overview" ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Tổng quan</span>
                    </a>
                    <a asp-action="Dashboard" asp-controller="Admin" asp-route-section="rooms" class="nav-item @(ViewBag.ActiveSection == "rooms" ? "active" : "")">
                        <i class="fas fa-building"></i>
                        <span>Phòng trọ</span>
                    </a>
                    <a asp-action="Index" asp-controller="Admin" class="nav-item @(ViewBag.ActiveSection == "users" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Người dùng</span>
                    </a>
                    <a asp-action="Dashboard" asp-controller="Admin" asp-route-section="posts" class="nav-item @(ViewBag.ActiveSection == "posts" ? "active" : "")">
                        <i class="fas fa-newspaper"></i>
                        <span>Bài đăng</span>
                    </a>
                    <div class="section-divider"></div>
                    <a asp-action="Dashboard" asp-controller="Admin" asp-route-section="settings" class="nav-item @(ViewBag.ActiveSection == "settings" ? "active" : "")">
                        <i class="fas fa-sliders-h"></i>
                        <span>Cài đặt</span>
                    </a>
                </div>
            </div>

            <!-- User Footer -->
            <div class="user-footer">
                <div class="user-info">
                    <div class="avatar-circle">@initials</div>
                    <div class="user-details">
                        <div class="user-name">@(currentUser?.FullName ?? currentUser?.UserName ?? "Administrator")</div>
                        <div class="user-role">@(userRoles.FirstOrDefault() ?? "Admin")</div>
                    </div>
                </div>
                <div class="logout-icon" id="logoutButton">
                    <i class="fas fa-sign-out-alt"></i>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>