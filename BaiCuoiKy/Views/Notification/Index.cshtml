@{
}
@model IEnumerable<BaiCuoiKy.Models.Notification>

<div class="container py-5" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <h3 class="fw-bold mb-4" style="color: #002641;">
                🔔 Trung tâm thông báo
            </h3>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="list-group list-group-flush">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="list-group-item p-4 border-start border-4 @(item.IsRead ? "border-light" : "border-danger bg-light")">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <p class="mb-1 @(item.IsRead ? "" : "fw-bold")" style="color: #002641; font-size: 1.05rem;">
                                            @item.Message
                                        </p>
                                        <small class="text-muted">
                                            📅 @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    @if (!item.IsRead)
                                    {
                                        <span class="badge rounded-pill bg-danger">Mới</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <p class="text-muted">Bạn không có thông báo nào.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>