@{
}
<nav class="navbar">
    <div class="nav-left">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>

        <div class="dropdown">
            <a href="#" class="dropdown-toggle">Danh mục </a>
            <ul class="dropdown-menu">
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="TruyenThong">Trọ truyền thống</a></li>
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="Ghep">Trọ ghép</a></li>
                <li><a asp-controller="Tro" asp-action="Index" asp-route-type="ChungCuMini">Chung cư mini</a></li>
            </ul>
        </div>

        <a asp-controller="Home" asp-action="Index">Chính sách bảo mật</a>
        <a asp-controller="Tro" asp-action="Index">Hỗ trợ</a>
    </div>

    <div class="nav-right">

        <!-- 🔍 Search -->
        <a asp-controller="Search" asp-action="Search" class="btn btn-primary">
            🔍 Tìm Kiếm
        </a>

        @if (User.Identity.IsAuthenticated)
        {
            if (User.IsInRole("Admin"))
            {
                <a asp-controller="Tro" asp-action="Create" class="btn btn-register">
                    + Đăng tin
                </a>
                <a asp-controller="Khachthue" asp-action="Bookings" class="nav-link">
                    Booking của tôi
                </a>
            }
            else
            {
                <a asp-controller="Booking" asp-action="Index" class="nav-link">
                    Đặt phòng
                </a>
            }

                <a asp-controller="Account" asp-action="Profile" class="btn btn-login">
                    👤
                </a>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn btn-logout">
                    Đăng xuất
                </button>
            </form>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-login">
                Đăng nhập
            </a>

            <a asp-controller="Account" asp-action="Register" class="btn btn-register">
                Đăng ký
            </a>
            
        }

    </div>
</nav>