@model IEnumerable<BaiCuoiKy.Models.Category>

@{
    ViewData["Title"] = "Danh mục phòng cho thuê - House88";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Category.css" asp-append-version="true" />
   
}

<div class="category-hero shadow-lg">
    <div class="container">
        <h1 class="fw-bold mb-3" style="font-family: var(--font-display); font-size: 3rem;">Khám Phá Danh Mục</h1>
        <p class="text-light opacity-75 mb-0" style="font-size: 1.1rem;">Tìm kiếm không gian sống lý tưởng theo nhu cầu của bạn</p>

        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
            <div class="mt-4">
                <button type="button" class="btn admin-action-btn shadow-sm" data-bs-toggle="modal" data-bs-target="#categoryModal">
                    <i class="fas fa-cog me-2"></i> Chỉnh sửa danh mục
                </button>
            </div>
        }
    </div>
</div>

<div class="container mb-5 pb-5">
    <div class="row g-4 justify-content-center">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <a asp-controller="Home" asp-action="Search" asp-route-categoryId="@item.Id" class="text-decoration-none">
                        <div class="category-card text-center h-100">
                            <div class="category-icon">
                                <i class="fas fa-building"></i>
                            </div>
                            <h5 class="fw-bold mb-2" style="color: var(--navy);">@item.TenDanhMuc</h5>

                            @if (!string.IsNullOrEmpty(item.MoTa))
                            {
                                <p class="text-muted small mb-0 px-2">@item.MoTa</p>
                            }
                        </div>
                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-folder-open fa-4x text-muted mb-3 opacity-25"></i>
                <p class="display-6 text-muted fs-4">Hiện chưa có danh mục nào trên hệ thống.</p>
            </div>
        }
    </div>
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    <div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                <div class="modal-header bg-dark text-white border-0 py-3">
                    <h5 class="modal-title fw-bold" id="categoryModalLabel"><i class="fas fa-tools me-2"></i> Quản Lý Danh Mục</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body bg-light p-4">

                    <div class="card mb-4 border-0 shadow-sm" style="border-radius: 12px;">
                        <div class="card-body p-4">
                            <h6 class="mb-3 fw-bold" style="color: var(--pink);"><i class="fas fa-plus-circle me-1"></i> Thêm danh mục mới</h6>
                            <form asp-controller="Category" asp-action="AddCategory" method="post" class="row g-3">
                                <div class="col-md-5">
                                    <input type="text" name="TenDanhMuc" class="form-control" placeholder="Tên danh mục..." required />
                                </div>
                                <div class="col-md-5">
                                    <input type="text" name="MoTa" class="form-control" placeholder="Mô tả ngắn..." />
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-success w-100 fw-bold">Thêm</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 text-secondary">Tên danh mục</th>
                                            <th class="text-secondary">Mô tả</th>
                                            <th class="text-center text-secondary">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null)
                                        {
                                            foreach (var item in Model)
                                            {
                                                <tr>
                                                    <form asp-controller="Category" asp-action="UpdateCategory" method="post">
                                                        <input type="hidden" name="Id" value="@item.Id" />
                                                    <td class="ps-4">
                                                        <input type="text" name="TenDanhMuc" value="@item.TenDanhMuc" class="form-control form-control-sm" required />
                                                    </td>
                                                    <td>
                                                        <input type="text" name="MoTa" value="@item.MoTa" class="form-control form-control-sm" />
                                                    </td>
                                                    <td class="text-center">
                                                        <button type="submit" class="btn btn-sm btn-primary me-1" title="Lưu thay đổi"><i class="fas fa-save"></i> Lưu</button>
                                                        <a asp-controller="Category" asp-action="DeleteCategory" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này? Lệnh này sẽ ảnh hưởng đến các phòng đang thuộc danh mục!');" title="Xóa">
                                                            <i class="fas fa-trash-alt"></i> Xóa
                                                        </a>
                                                    </td>
                                                    </form>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}