@{
    Layout = "_AdminLayout";
    ViewBag.Title = "Quản lý phòng trọ";
    ViewBag.ActiveSection = "rooms";
    var rooms = ViewBag.Rooms as List<Tro> ?? new List<Tro>();
}

@model dynamic
@functions {
    // Helper method format giá tiền
    public string FormatPrice(decimal? price)
    {
        return price.HasValue ? price.Value.ToString("N0") : "0";
    }

    // Helper method format ngày tháng
    public string FormatDate(DateTime? date)
    {
        return date.HasValue ? date.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật";
    }
}


<div class="admin-rooms-container">

    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-title">Quản lý phòng trọ</h1>
            <p class="admin-page-subtitle">Danh sách tất cả phòng trọ trên hệ thống</p>
        </div>
        <div>
            <a href="@Url.Action("Create", "Tro")" class="admin-btn admin-btn-primary">
                <i class="fas fa-plus"></i>
                <span>Thêm phòng trọ</span>
            </a>
        </div>
    </div>
    <div class="admin-rooms-container">
        <div class="admin-page-header">
        </div>

        <div class="admin-filter-section">
            <form method="get" action="">
                <input type="hidden" name="section" value="rooms" />

                <div class="filter-grid">
                    <div class="filter-group">
                        <label>Tìm kiếm</label>
                        <input type="text" name="searchKeyword" value="@ViewBag.SearchKeyword" class="admin-input" placeholder="Tên phòng, địa chỉ..." />
                    </div>

                    <div class="filter-group">
                        <label>Trạng thái</label>
                        <select name="status" class="admin-input">
                            <option value="">-- Tất cả trạng thái --</option>
                            <option value="0" selected="@(ViewBag.Status?.ToString() == "0")">Đang trống</option>
                            <option value="1" selected="@(ViewBag.Status?.ToString() == "1")">Đang xử lý</option>
                            <option value="2" selected="@(ViewBag.Status?.ToString() == "2")">Đã cho thuê</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Danh mục</label>
                        <select name="categoryId" class="admin-input">
                            <option value="">-- Tất cả danh mục --</option>
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id" selected="@(ViewBag.CategoryId?.ToString() == cat.Id.ToString())">
                                        @cat.TenDanhMuc
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label>Giá từ (VNĐ)</label>
                        <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="admin-input" placeholder="Tối thiểu..." min="0" />
                    </div>

                    <div class="filter-group">
                        <label>Đến giá (VNĐ)</label>
                        <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="admin-input" placeholder="Tối đa..." min="0" />
                    </div>

                    <div class="filter-group admin-filter-actions">
                        <button type="submit" class="admin-btn admin-btn-primary">
                            <i class="fas fa-search"></i> Lọc
                        </button>
                        <a href="?section=rooms" class="admin-btn admin-btn-outline">
                            <i class="fas fa-sync"></i> Khôi phục
                        </a>
                    </div>
                </div>
            </form>
        </div>
        <div class="admin-rooms-table-wrapper">

    <div class="admin-rooms-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên phòng / Tiêu đề</th>
                    <th>Địa chỉ</th>
                    <th>Giá</th>
                    <th>Chủ trọ</th>
                    <th>Trạng thái</th>
                    <th>Ngày đăng</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (rooms != null && rooms.Any())
                {
                    foreach (var tro in rooms)
                    {
                        <tr>
                            <td>@tro.Id</td>
                            <td>
                                <div class="admin-room-title">
                                    @if (tro.AnhPhongs != null && tro.AnhPhongs.Any())
                                    {
                                        <img src="@tro.AnhPhongs.First().Url" alt="@tro.TieuDe" class="admin-room-thumbnail" />
                                    }
                                    else
                                    {
                                        <div class="admin-room-thumbnail-placeholder">
                                            <i class="fas fa-image"></i>
                                        </div>
                                    }
                                    <span class="admin-room-name">@tro.TieuDe</span>
                                </div>
                            </td>
                            <td>@tro.DiaChi</td>

                            
                            <td class="admin-price">@FormatPrice(tro.Gia) VNĐ/ Tháng</td>

                            <td>
                                <div class="admin-owner-info">
                                    <i class="fas fa-user-circle"></i>
                                    <span>@(tro.User?.FullName ?? tro.User?.UserName ?? "Không xác định")</span>
                                </div>
                            </td>
                            <td>
                                @if (tro.TrangThai == TrangThaiPhong.DangTrong)
                                {
                                    <span class="admin-badge admin-badge-success">🟢 Đang trống</span>
                                }
                                else if (tro.TrangThai == TrangThaiPhong.DangXuLy)
                                {
                                    <span class="admin-badge admin-badge-warning">🟡 Đang xử lý</span>
                                }
                                else if (tro.TrangThai == TrangThaiPhong.DaChoThue)
                                {
                                    <span class="admin-badge admin-badge-danger">🔴 Đã cho thuê</span>
                                }
                            </td>

                            <!-- Sửa dòng này - gọi FormatDate -->
                            <td>@FormatDate(tro.NgayDang)</td>

                            <td class="admin-actions">
                                <a href="@Url.Action("RoomDetail", "Admin", new { id = tro.Id })" class="admin-action-btn admin-action-view" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", "Tro", new { id = tro.Id })" class="admin-action-btn admin-action-edit" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button type="button" class="admin-action-btn admin-action-delete" onclick="confirmDelete(@tro.Id, '@tro.TieuDe')" title="Xóa">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="admin-empty-state">
                            <i class="fas fa-building"></i>
                            <p>Chưa có phòng trọ nào</p>
                            <a href="@Url.Action("Create", "Tro")" class="admin-btn admin-btn-outline">Thêm phòng trọ đầu tiên</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Form xóa ẩn -->
<form id="deleteForm" method="post" action="@Url.Action("Delete", "Tro")" style="display: none;">
    <input type="hidden" name="id" id="deleteRoomId" />
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <!-- File JS dùng chung của bạn -->
    <script src="~/js/Admin-Rooms.js"></script>

    <!-- Khối JS xử lý nút xóa -->
    <script>
        function confirmDelete(id, title) {
            if (confirm(`Bạn có chắc chắn muốn xóa phòng trọ "${title}"? Hành động này không thể hoàn tác.`)) {
                document.getElementById('deleteRoomId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}
@section Styles {
    <link rel="stylesheet" href="~/css/Admin-Rooms.css" asp-append-version="true" />
}