@{
    Layout = "_Layout";
    ViewBag.Title = "Thêm phòng trọ mới";
}

@model BaiCuoiKy.Models.ViewModel.CreateTroViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle me-2"></i>
                        Thêm phòng trọ mới
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form id="createForm" asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="TieuDe" class="form-label fw-bold">
                                <i class="fas fa-heading me-1 text-primary"></i> Tiêu đề
                            </label>
                            <input asp-for="TieuDe" class="form-control" placeholder="Ví dụ: Phòng trọ mới xây, gần trường Đại học..." />
                            <span asp-validation-for="TieuDe" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiaChi" class="form-label fw-bold">
                                <i class="fas fa-map-marker-alt me-1 text-primary"></i> Địa chỉ
                            </label>
                            <input asp-for="DiaChi" class="form-control" placeholder="Số nhà, đường, phường/xã, quận/huyện, thành phố" />
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gia" class="form-label fw-bold">
                                    <i class="fas fa-dollar-sign me-1 text-primary"></i> Giá tiền (VNĐ/tháng)
                                </label>
                                <input asp-for="Gia" class="form-control" type="number" step="10000" placeholder="Ví dụ: 2000000" />
                                <span asp-validation-for="Gia" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DienTich" class="form-label fw-bold">
                                    <i class="fas fa-ruler-combined me-1 text-primary"></i> Diện tích (m²)
                                </label>
                                <input asp-for="DienTich" class="form-control" type="number" step="0.1" placeholder="Ví dụ: 25" />
                                <span asp-validation-for="DienTich" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MoTa" class="form-label fw-bold">
                                <i class="fas fa-align-left me-1 text-primary"></i> Mô tả chi tiết
                            </label>
                            <textarea asp-for="MoTa" class="form-control" rows="5" placeholder="Mô tả về phòng trọ, tiện ích, nội thất, điều kiện thuê,..."></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-images me-1 text-primary"></i> Hình ảnh
                            </label>
                            <input type="file" name="Images" class="form-control" multiple accept="image/*" />
                            <div class="form-text">
                                <i class="fas fa-info-circle"></i> Bạn có thể chọn nhiều ảnh. Hỗ trợ định dạng: JPG, PNG, JPEG
                            </div>
                            <div id="imagePreview" class="row mt-3"></div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold">
                                <i class="fas fa-tags me-1 text-primary"></i> Danh mục
                            </label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                                @if (Model.Categories != null && Model.Categories.Any())
                                {
                                    foreach (var category in Model.Categories)
                                    {
                                        <option value="@category.Id">@category.TenDanhMuc</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                            <div class="form-text">
                                <i class="fas fa-info-circle"></i> Chọn danh mục phù hợp cho phòng trọ
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrangThai" class="form-label fw-bold">
                                <i class="fas fa-info-circle me-1 text-primary"></i> Trạng thái
                            </label>

                            <select asp-for="TrangThai" class="form-select">
                                <option value="0">Đang trống</option>
                                <option value="1">Đang xử lý</option>
                                <option value="2">Đã cho thuê</option>
                            </select>

                            <span asp-validation-for="TrangThai" class="text-danger"></span>

                            <div class="form-text">
                                Chọn trạng thái hiện tại của phòng
                            </div>
                        </div>

                        <div class="alert alert-success">
                            <i class="fas fa-crown me-2"></i>
                            <strong>Quản trị viên:</strong> Phòng trọ sẽ được hiển thị công khai ngay sau khi thêm.
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="button" id="btnBack" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại
                            </button>
                            <button type="button" id="btnSubmit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Thêm phòng trọ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/CreateRoom.js"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/CreateRoom.css" asp-append-version="true" />
}