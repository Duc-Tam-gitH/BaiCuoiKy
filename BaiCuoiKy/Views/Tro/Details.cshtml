@model BaiCuoiKy.Models.Tro
@using System.Security.Claims

@{
    ViewData["Title"] = Model.TieuDe;
}

@section Styles {
    <link rel="stylesheet" href="~/css/Details.css" asp-append-version="true" />
}

<div class="details-container">

    @* ─────────────────────────────────────────
       1. CONTENT AREA (LEFT)
    ───────────────────────────────────────── *@
    <div class="room-details__content">

        <div class="room-details__hero">

            <div class="room-gallery">
                @if (!string.IsNullOrEmpty(Model.KhuVuc))
                {
                    <span class="room-gallery__badge">@Model.KhuVuc</span>
                }

                <div id="roomImageCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @if (Model.AnhPhongs != null && Model.AnhPhongs.Any())
                        {
                            var index = 0;
                            foreach (var anh in Model.AnhPhongs)
                            {
                                <div class="carousel-item @(index == 0 ? "active" : "")">
                                    <img src="@anh.Url" class="d-block w-100" alt="Ảnh phòng @Model.TieuDe" />
                                </div>
                                index++;
                            }
                        }
                        else
                        {
                            <div class="carousel-item active">
                                <img src="https://via.placeholder.com/800x480?text=House88" class="d-block w-100" alt="House88 Placeholder" />
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#roomImageCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#roomImageCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>

            <div class="room-details__header">
                <h2 class="room-details__title">@Model.TieuDe</h2>
                <p class="room-details__price">
                    @String.Format("{0:N0}", Model.Gia)
                    <span>VNĐ / tháng</span>
                </p>
                <div class="room-details__meta">
                    <span><i class="fas fa-ruler-combined me-2"></i> @Model.DienTich m²</span>
                    <span><i class="fas fa-tag me-2"></i> @Model.Category?.TenDanhMuc</span>
                </div>
                <p class="small text-muted mb-0 mt-1"><i class="fas fa-map-marker-alt me-1 text-danger"></i> @Model.DiaChi</p>
            </div>
        </div>

        <hr class="my-4 opacity-50" />

        <div class="room-details__description">
            <h3>Mô Tả Chi Tiết</h3>
            <p>@Html.Raw(Model.MoTa)</p>
        </div>


        <hr class="my-5 opacity-50" />

        <div class="room-reviews">
            <h3>Đánh Giá & Nhận Xét</h3>
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div class="review-list">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.NgayDanhGia))
                    {
                        <div class="review-item">
                            <div class="review-item__avatar">
                                @(string.IsNullOrEmpty(review.User?.FullName) ? "U" : review.User.FullName.Substring(0, 1).ToUpper())
                            </div>
                            <div class="review-item__content">
                                <div class="review-item__header">
                                    <h5>@(review.User?.FullName ?? "Người dùng")</h5>
                                    <span class="review-item__date">@review.NgayDanhGia.ToString("dd/MM/yyyy")</span>
                                </div>
                                <div class="review-item__rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= review.Rating ? "" : "text-light") opacity-75 me-1"></i>
                                    }
                                    }
                                </div>
                                <p class="review-item__text">@review.Comment</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="reviews-empty">
                    <i class="far fa-comments fa-2x mb-2 opacity-50"></i>
                    <p>Chưa có đánh giá nào cho phòng này.</p>
                </div>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <div class="submit-review shadow-sm mt-5">
                    <h4>Gửi đánh giá của bạn</h4>
                    <form asp-controller="Home" asp-action="PostReview" method="post">
                        <input type="hidden" name="TroId" value="@Model.Id" />

                        <div class="rating-select">
                            <label>Xếp hạng sao:</label>
                            <select name="Rating" required>
                                <option value="5">⭐⭐⭐⭐⭐ 5 Sao</option>
                                <option value="4">⭐⭐⭐⭐ 4 Sao</option>
                                <option value="3">⭐⭐⭐ 3 Sao</option>
                                <option value="2">⭐⭐ 2 Sao</option>
                                <option value="1">⭐ 1 Sao</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <textarea name="Comment" class="form-control" rows="4" placeholder="Nhận xét của bạn..." required></textarea>
                        </div>

                        <button type="submit" class="btn btn-submit w-100">Gửi đánh giá <i class="fas fa-paper-plane ms-2"></i></button>
                    </form>
                </div>
            }
            else
            {
                <div class="submit-review bg-light text-muted border text-center mt-5">
                    <p>Đăng nhập để gửi đánh giá. <a asp-controller="Account" asp-action="Login" class="text-danger fw-bold">Đăng nhập</a></p>
                </div>
            }
        </div>
    </div>

    @* ─────────────────────────────────────────
       2. SIDEBAR (RIGHT)
    ───────────────────────────────────────── *@
    <div class="details-sidebar">

        <div class="contact-card">
            <div class="contact-card__avatar">
                @(string.IsNullOrEmpty(Model.User?.FullName) ? "C" : Model.User.FullName.Substring(0, 1).ToUpper())
            </div>
            <div class="contact-card__info">
                <h4>@(Model.User?.FullName ?? "Chủ phòng")</h4>
                <p>Chủ phòng</p>
            </div>

            <div class="contact-card__actions">
                <a href="tel:@(Model.User?.PhoneNumber ?? "#")" class="btn-contact btn-contact--phone">
                    <i class="fas fa-phone-alt"></i> Gọi điện
                </a>
                <a href="https://zalo.me/@(Model.User?.PhoneNumber ?? "#")" target="_blank" class="btn-contact btn-contact--message">
                    <i class="fab fa-facebook-messenger"></i> Chat Zalo
                </a>

                @if (Model.TrangThai == BaiCuoiKy.Models.TrangThaiPhong.DangTrong)
                {
                    <form asp-controller="Tro" asp-action="BookRoom" method="post" class="w-100 mt-2">
                        <input type="hidden" name="troId" value="@Model.Id" />
                        <button type="submit" class="btn-contact w-100 border-0" style="background-color: #28a745; color: white;">
                            <i class="fas fa-calendar-check me-2"></i> Đặt phòng ngay
                        </button>
                    </form>
                }
                else if (Model.TrangThai == BaiCuoiKy.Models.TrangThaiPhong.DaChoThue)
                {
                    <div class="alert alert-danger w-100 mt-2 py-2 mb-0 small text-center">
                        <i class="fas fa-info-circle me-1"></i> Phòng đã có người thuê
                    </div>
                }
            </div>
        </div>

        <div class="map-section">
            <h6 class="small fw-bold text-muted mb-3">Vị trí</h6>
            <div class="map-placeholder">
                <i class="fas fa-map-marked-alt me-2 opacity-50"></i>
                Map placeholder
            </div>
        </div>
    </div>
</div>